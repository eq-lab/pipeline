# ── Shared (API + Worker) ────────────────────────────────────

POSTGRES_URL=postgres://user:password@localhost:5432/pipeline

# ── Sumsub KYC (API + Worker) ───────────────────────────────

SUMSUB_APP_TOKEN=                    # required
SUMSUB_SECRET_KEY=                   # required
SUMSUB_BASE_URL=https://api.sumsub.com  # required
SUMSUB_VERIFICATION_LEVEL=           # required, e.g. "id-and-liveness"
SUMSUB_WEBHOOK_SECRET_KEY=           # required, for webhook HMAC validation
SUMSUB_SANDBOX=false                 # optional, default false
SUMSUB_TOKEN_TTL_SECS=600           # optional, default 600

# ── API ─────────────────────────────────────────────────────

API_PORT=8080                        # optional, default 8080

# ── Worker: Transfer Indexer (JOB_TRANSFERS_) ─────────────────

JOB_TRANSFERS_ENABLED=false
JOB_TRANSFERS_ETH_RPC_URL=https://mainnet.infura.io/v3/<key>
JOB_TRANSFERS_CHAIN_ID=1
JOB_TRANSFERS_START_BLOCK=0                        # optional, default 0 — seed cursor on first run
JOB_TRANSFERS_TRANSFER_CONTRACTS=0xabc...,0xdef...  # required, comma-separated ERC-20 contract addresses
JOB_TRANSFERS_TRANSFER_TARGETS=0xabc...,0xdef...    # required, only index transfers where from or to is in this list
JOB_TRANSFERS_POLLING_BLOCK_RANGE=1000              # optional, default 1000
JOB_TRANSFERS_POLLING_INTERVAL_MS=5000              # optional, default 500
JOB_TRANSFERS_LOG_CONFIRMATIONS_DELAY=12            # optional, default 12

# ── Worker: Withdrawal Queue Indexer (JOB_WQ_) ───────────────

JOB_WQ_ENABLED=false
JOB_WQ_ETH_RPC_URL=https://mainnet.infura.io/v3/<key>
JOB_WQ_CHAIN_ID=1
JOB_WQ_WQ_CONTRACTS=0xabc...                       # required, comma-separated WithdrawalQueue contract addresses
JOB_WQ_POLLING_BLOCK_RANGE=1000                    # optional, default 1000
JOB_WQ_POLLING_INTERVAL_MS=5000                    # optional, default 500
JOB_WQ_LOG_CONFIRMATIONS_DELAY=12                  # optional, default 12

# ── Worker: KYC Outbox (JOB_KYC_) ────────────────────────────

JOB_KYC_ENABLED=false
JOB_KYC_INTERVAL_SECS=30                           # optional, default 30
JOB_KYC_BATCH_SIZE=100                             # optional, default 100

# ── Worker: Whitelist Sync (JOB_WHITELIST_) ───────────────────

JOB_WHITELIST_ENABLED=false
JOB_WHITELIST_INTERVAL_SECS=30                     # optional, default 30
JOB_WHITELIST_TTL_SECS=7776000                     # optional, default 90 days
JOB_WHITELIST_ETH_RPC_URL=https://mainnet.infura.io/v3/<key>
JOB_WHITELIST_REGISTRY_ADDRESS=0x...               # WhitelistRegistry contract address
JOB_WHITELIST_SIGNER_KEY=0x...                     # private key with WHITELIST_ADMIN role
