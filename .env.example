# Shared database (all jobs use the same DB; migrations run once at startup)
POSTGRES_URL=postgres://user:password@localhost:5432/pipeline

# Comma-separated list of job names (e.g. ETH_MAINNET)
JOB_NAMES=

# Per-job config — replace <NAME> with the uppercased job name (e.g. ETH_MAINNET)
JOB_<NAME>_ENABLED=true
JOB_<NAME>_ETH_RPC_URL=https://mainnet.infura.io/v3/<key>
JOB_<NAME>_CHAIN_ID=1
JOB_<NAME>_POLLING_CONTRACTS=0xabc...,0xdef...   # required, comma-separated ERC-20 contract addresses to watch
JOB_<NAME>_POLLING_TARGETS=0xabc...,0xdef...     # required, only index transfers where from or to is in this list
JOB_<NAME>_POLLING_BLOCK_RANGE=1000      # optional, default 1000
JOB_<NAME>_POLLING_INTERVAL_MS=500       # optional, default 500
JOB_<NAME>_LOG_CONFIRMATIONS_DELAY=12    # optional, default 12
