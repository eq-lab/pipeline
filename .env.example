# ── Shared (API + Worker) ────────────────────────────────────

POSTGRES_URL=postgres://user:password@localhost:5432/pipeline   # accepted fallback: DATABASE_URL (Heroku/Railway convention)
BITGO_BASE_URL=https://app.bitgo-test.com    # required
BITGO_ACCESS_TOKEN=                          # required
BITGO_WALLET_ID=                             # required
BITGO_NATIVE_SYMBOL=hteth                    # optional, default "hteth"; use "eth" for mainnet
CRYSTAL_ENABLED=true                         # optional, default true — if false, Crystal KYT checks skipped (API + Relayer)

# ── Sumsub KYC (API + Worker) ───────────────────────────────

SUMSUB_APP_TOKEN=                    # required
SUMSUB_SECRET_KEY=                   # required
SUMSUB_BASE_URL=https://api.sumsub.com  # required
SUMSUB_VERIFICATION_LEVEL=           # required, e.g. "id-and-liveness"
SUMSUB_WEBHOOK_SECRET_KEY=           # required, for webhook HMAC validation
SUMSUB_SANDBOX=false                 # optional, default false
SUMSUB_TOKEN_TTL_SECS=600           # optional, default 600

# ── API ─────────────────────────────────────────────────────

API_PORT=8080                        # optional, default 8080

# Multi-chain config (replaces API_CHAIN_ID / API_SIGNER_KEY / API_DM_ADDRESS / API_WQ_ADDRESS):
CHAINS=1                             # required — comma-separated chain IDs (e.g. "1" for single-chain, "1,99999" for multi-chain)
DEFAULT_CHAIN_ID=1                   # required — must be a member of CHAINS; used as fallback when no chain_id query param is supplied

# Per-chain API voucher signing (replace <id> with each value from CHAINS):
# CHAIN_<id>_SIGNER_KEY=0x...        # optional — private key for EIP-712 voucher signing on this chain
# CHAIN_<id>_DM_ADDRESS=0x...        # required when SIGNER_KEY is set — DepositManager contract address
# CHAIN_<id>_WQ_ADDRESS=0x...        # required when SIGNER_KEY is set — WithdrawalQueue contract address
#
# Example for a single-chain Ethereum mainnet deployment:
# CHAIN_1_SIGNER_KEY=0x...
# CHAIN_1_DM_ADDRESS=0x...
# CHAIN_1_WQ_ADDRESS=0x...

# ── Worker: Job-level (un-sharded) ──────────────────────────

JOB_INDEXER_ENABLED=false
JOB_PRICE_POLLER_ENABLED=false
JOB_KYC_ENABLED=false
JOB_RELAYER_ENABLED=false

# Indexer tuning (job-level, applies to all chains):
JOB_INDEXER_POLLING_BLOCK_RANGE=1000               # optional, default 1000
JOB_INDEXER_POLLING_INTERVAL_MS=500                # optional, default 500
JOB_INDEXER_LOG_CONFIRMATIONS_DELAY=12             # optional, default 12
JOB_INDEXER_IPFS_GATEWAY_URL=https://ipfs.io/ipfs/ # optional, default https://ipfs.io/ipfs/ — used to fetch LoanDrawn metadata JSON

# Price poller tuning (job-level, applies to all chains):
JOB_PRICE_POLLER_START_BLOCK=0                           # block to start collecting prices from
JOB_PRICE_POLLER_BLOCK_INTERVAL=300                      # optional, default 300 — collect a snapshot every N blocks
JOB_PRICE_POLLER_POLL_INTERVAL_SECS=10                   # optional, default 60 — seconds between RPC polling cycles
JOB_PRICE_POLLER_RPC_DELAY_MS=5000                       # optional, default 200 — ms to sleep between individual RPC calls during backfill
# Vault addresses are read from the `vaults` table (no env config needed)

# Relayer tuning (job-level, applies to all chains):
JOB_RELAYER_INTERVAL_SECS=60                       # optional, default 60
JOB_RELAYER_SUMSUB_ENABLED=true                    # optional, default true — if false, Sumsub checks skipped and its env vars not required
JOB_RELAYER_YIELD_MINTER_BATCH_SIZE=50            # optional, default 50 — max rows processed per cycle

# KYC outbox tuning (job-level):
JOB_KYC_INTERVAL_SECS=30                           # optional, default 30
JOB_KYC_BATCH_SIZE=100                             # optional, default 100

# ── Worker: Per-chain config ─────────────────────────────────
#
# All three jobs (indexer, price-poller, relayer) read per-chain settings from
# CHAIN_<id>_* env vars. Replace <id> with each chain ID from CHAINS.
#
# Example for a single-chain Ethereum mainnet deployment (CHAINS=1):
#
# CHAIN_1_ETH_RPC_URL=https://mainnet.infura.io/v3/<key>          # required (indexer + price-poller + relayer)
# CHAIN_1_START_BLOCK=0                                             # optional, default 0 — seed cursor on first run
# CHAIN_1_DM_CONTRACTS=0xabc...                                     # required — comma-separated DepositManager contract addresses
# CHAIN_1_WQ_CONTRACTS=0xabc...                                     # required — comma-separated WithdrawalQueue contract addresses
# CHAIN_1_SPLUSD_CONTRACTS=0xabc...                                 # required — comma-separated sPLUSD vault contract addresses
# CHAIN_1_LOAN_REGISTRY_CONTRACTS=0xabc...                          # required — comma-separated LoanRegistry contract addresses
# CHAIN_1_YIELD_MINTER_CONTRACTS=0xabc...                           # required — comma-separated PipelineYieldMinter contract addresses
# CHAIN_1_RELAYER_SIGNER_KEY=0x...                                  # required (relayer) — private key for whitelist txs
# CHAIN_1_RELAYER_REGISTRY_ADDRESS=0x...                            # required (relayer) — WhitelistRegistry contract address
# CHAIN_1_RELAYER_YIELD_MINTER_ADDRESS=0x...                        # required (relayer) — PipelineYieldMinter contract address
# CHAIN_1_RELAYER_LOAN_REGISTRY_ADDRESS=0x...                       # required (relayer) — LoanRegistry contract address

# ── Crystal Intelligence KYT (Worker: Relayer) ───────────────

CRYSTAL_API_KEY=                                   # required when CRYSTAL_ENABLED=true
CRYSTAL_BASE_URL=https://apiexpert.crystalblockchain.com  # optional, default https://apiexpert.crystalblockchain.com
CRYSTAL_BLOCKCHAIN=eth                             # optional, omit to check all chains; required for transaction checks
CRYSTAL_TOKEN_ID=138052                            # optional, default 0 (base asset) — see /monitor/currency/list for token IDs
CRYSTAL_RISK_SCORE_THRESHOLD=0.7                   # optional, default 0.7 (0.0–1.0)
# optional, comma-separated signal names — default: all 24 signals
CRYSTAL_HARD_FAIL_SIGNALS="child_exploitation,dark_market,dark_service,enforcement_action,exchange_fraudulent,gambling,illegal_service,mixer,ransom,sanctions,scam,stolen_coins,terrorism_financing"

# ── Frontend (VITE_) ────────────────────────────────────────────────────────

VITE_API_BASE_URL=http://localhost:8080
VITE_EVM_CHAIN_ID=560048
VITE_EVM_RPC_URL=https://ethereum-hoodi-rpc.publicnode.com
VITE_DEPOSIT_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000  # set to DepositManager contract address on Hoodi
VITE_WITHDRAWAL_QUEUE_ADDRESS=0x0000000000000000000000000000000000000000  # set to WithdrawalQueue contract address on Hoodi
VITE_STAKED_PLUSD_ADDRESS=0x0000000000000000000000000000000000000000  # set to StakedPLUSD vault address on Hoodi
VITE_WALLETCONNECT_PROJECT_ID=replace-me                                 # provision at https://cloud.reown.com

# Stellar
VITE_STELLAR_NETWORK=testnet                                             # "testnet" (default) or "mainnet"
VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org             # Stellar Horizon base URL
VITE_STELLAR_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5  # Circle USDC issuer (testnet)
