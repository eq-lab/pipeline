# ── Shared (API + Worker) ────────────────────────────────────

POSTGRES_URL=postgres://user:password@localhost:5432/pipeline   # accepted fallback: DATABASE_URL (Heroku/Railway convention)
BITGO_BASE_URL=https://app.bitgo-test.com    # required
BITGO_ACCESS_TOKEN=                          # required
BITGO_WALLET_ID=                             # required
BITGO_NATIVE_SYMBOL=hteth                    # optional, default "hteth"; use "eth" for mainnet
CRYSTAL_ENABLED=true                         # optional, default true — if false, Crystal KYT checks skipped (API + Relayer)

# ── Sumsub KYC (API + Worker) ───────────────────────────────

SUMSUB_APP_TOKEN=                    # required
SUMSUB_SECRET_KEY=                   # required
SUMSUB_BASE_URL=https://api.sumsub.com  # required
SUMSUB_VERIFICATION_LEVEL=           # required, e.g. "id-and-liveness"
SUMSUB_WEBHOOK_SECRET_KEY=           # required, for webhook HMAC validation
SUMSUB_SANDBOX=false                 # optional, default false
SUMSUB_TOKEN_TTL_SECS=600           # optional, default 600

# ── API ─────────────────────────────────────────────────────

API_PORT=8080                        # optional, default 8080

# Multi-chain config (replaces API_CHAIN_ID / API_SIGNER_KEY / API_DM_ADDRESS / API_WQ_ADDRESS):
CHAINS=1                             # required — comma-separated chain IDs (e.g. "1" for single-chain, "1,99999" for multi-chain)
DEFAULT_CHAIN_ID=1                   # required — must be a member of CHAINS; used as fallback when no chain_id query param is supplied

# Per-chain API voucher signing (replace <id> with each value from CHAINS):
# CHAIN_<id>_SIGNER_KEY=0x...        # optional — private key for EIP-712 voucher signing on this chain
# CHAIN_<id>_DM_ADDRESS=0x...        # required when SIGNER_KEY is set — DepositManager contract address
# CHAIN_<id>_WQ_ADDRESS=0x...        # required when SIGNER_KEY is set — WithdrawalQueue contract address
#
# Example for a single-chain Ethereum mainnet deployment:
# CHAIN_1_SIGNER_KEY=0x...
# CHAIN_1_DM_ADDRESS=0x...
# CHAIN_1_WQ_ADDRESS=0x...

# ── Worker: Job-level (un-sharded) ──────────────────────────

JOB_INDEXER_ENABLED=false
JOB_PRICE_POLLER_ENABLED=false
JOB_KYC_ENABLED=false
JOB_RELAYER_ENABLED=false

# Indexer tuning (job-level, applies to all chains):
JOB_INDEXER_POLLING_BLOCK_RANGE=1000               # optional, default 1000
JOB_INDEXER_POLLING_INTERVAL_MS=500                # optional, default 500
JOB_INDEXER_LOG_CONFIRMATIONS_DELAY=12             # optional, default 12
JOB_INDEXER_IPFS_GATEWAY_URL=https://ipfs.io/ipfs/ # optional, default https://ipfs.io/ipfs/ — used to fetch LoanDrawn metadata JSON

# Price poller tuning (job-level, applies to all chains):
JOB_PRICE_POLLER_START_BLOCK=0                           # block to start collecting prices from
JOB_PRICE_POLLER_BLOCK_INTERVAL=300                      # optional, default 300 — collect a snapshot every N blocks
JOB_PRICE_POLLER_POLL_INTERVAL_SECS=10                   # optional, default 60 — seconds between RPC polling cycles
JOB_PRICE_POLLER_RPC_DELAY_MS=5000                       # optional, default 200 — ms to sleep between individual RPC calls during backfill
# Vault addresses are read from the `vaults` table (no env config needed)

# Relayer tuning (job-level, applies to all chains):
JOB_RELAYER_INTERVAL_SECS=60                       # optional, default 60
JOB_RELAYER_SUMSUB_ENABLED=true                    # optional, default true — if false, Sumsub checks skipped and its env vars not required
JOB_RELAYER_YIELD_MINTER_BATCH_SIZE=50            # optional, default 50 — max rows processed per cycle

# KYC outbox tuning (job-level):
JOB_KYC_INTERVAL_SECS=30                           # optional, default 30
JOB_KYC_BATCH_SIZE=100                             # optional, default 100

# ── Worker: Per-chain config ─────────────────────────────────
#
# All three jobs (indexer, price-poller, relayer) read per-chain settings from
# CHAIN_<id>_* env vars. Replace <id> with each chain ID from CHAINS.
#
# Example for a single-chain Ethereum mainnet deployment (CHAINS=1):
#
# CHAIN_1_ETH_RPC_URL=https://mainnet.infura.io/v3/<key>          # required (indexer + price-poller + relayer)
# CHAIN_1_START_BLOCK=0                                             # optional, default 0 — seed cursor on first run
# CHAIN_1_DM_CONTRACTS=0xabc...                                     # required — comma-separated DepositManager contract addresses
# CHAIN_1_WQ_CONTRACTS=0xabc...                                     # required — comma-separated WithdrawalQueue contract addresses
# CHAIN_1_SPLUSD_CONTRACTS=0xabc...                                 # required — comma-separated sPLUSD vault contract addresses
# CHAIN_1_LOAN_REGISTRY_CONTRACTS=0xabc...                          # required — comma-separated LoanRegistry contract addresses
# CHAIN_1_YIELD_MINTER_CONTRACTS=0xabc...                           # required — comma-separated PipelineYieldMinter contract addresses
# CHAIN_1_RELAYER_SIGNER_KEY=0x...                                  # required (relayer) — private key for whitelist txs
# CHAIN_1_RELAYER_REGISTRY_ADDRESS=0x...                            # required (relayer) — WhitelistRegistry contract address
# CHAIN_1_RELAYER_YIELD_MINTER_ADDRESS=0x...                        # required (relayer) — PipelineYieldMinter contract address
# CHAIN_1_RELAYER_LOAN_REGISTRY_ADDRESS=0x...                       # required (relayer) — LoanRegistry contract address

# ── Stellar chain example (Worker: Indexer) ──────────────────
#
# Add Stellar testnet alongside the EVM chain: CHAINS=1,99000001
# The 99M+ range is the non-EVM sentinel (99000001=testnet, 99000002=mainnet).
#
# CHAIN_99000001_TYPE=stellar
# CHAIN_99000001_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
# CHAIN_99000001_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
#   (omit NETWORK_PASSPHRASE for testnet sentinel — defaults automatically)
# CHAIN_99000001_STELLAR_DEPOSIT_MANAGER_ID=CARFA2QETOZVKHSG4BCEEXMJHTYR2Z75VR7WQNX4MWZ33RQMKRKATIVI
# CHAIN_99000001_STELLAR_WITHDRAWAL_QUEUE_ID=CC3TWGFXP2XUZJXGLVTM2G4K2PF2YTC6BKDRPZIUPSVETNYAO57GU3Q7
# CHAIN_99000001_STELLAR_STAKED_PLUSD_ID=CDO4X3HCPR44UGXJ5PE35JBB4SYVDRQETXXOPQZLB7THN6FOTBTRKLW5
# CHAIN_99000001_STELLAR_ACCESS_MANAGER_ID=CBJUO44GFUU3NTDTTNJTLLIIC6RGNAS6NLPNIJYYZKFY5NSZ3IMMZ4Q5
#   (indexer does not read ACCESS_MANAGER_ID — for documentation only)
# CHAIN_99000001_STELLAR_USDC_ASSET_ID=CCWX3TKH3K5SQDPOBGQTGOGE6Q5VEZWCOYJ2HDVV5U6GNN5U4WOEB3C7
#   (indexer does not read USDC_ASSET_ID — for documentation only)
# CHAIN_99000001_STELLAR_PLUSD_ASSET_ID=CAC7JMGRFZBL4IS4WBO5R3AMTK3C53FEOQZSU2WL5C4TWCRFAYWFSIBN
#   (indexer does not read PLUSD_ASSET_ID — for documentation only)
# CHAIN_99000001_START_LEDGER=0      # set to a ledger within the last 7 days at startup
#   WARNING: Soroban RPC only keeps ~7 days of event history. If START_LEDGER is
#   older than 7 days the indexer will log a warning and produce no rows until
#   a recent START_LEDGER is configured.
#
# Price-poller (Stellar) — samples staked_pl_usd.convert_to_assets(1 share) at the current ledger.
# Vault address comes from the `vaults` DB table; this section only configures RPC + cadence.
#
# Optional — RPC URL and passphrase fall back to the indexer's CHAIN_<id>_STELLAR_* vars when unset.
# CHAIN_99000001_PRICE_POLLER_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
# CHAIN_99000001_PRICE_POLLER_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
#
# Cadence — per-chain Stellar-specific (default 60s). Independent of the EVM arm's
# JOB_PRICE_POLLER_POLL_INTERVAL_SECS so the two chain kinds can be tuned separately.
# CHAIN_99000001_PRICE_POLLER_STELLAR_INTERVAL_SECS=10
#
# JOB_PRICE_POLLER_START_BLOCK / _BLOCK_INTERVAL / _RPC_DELAY_MS are EVM-only and are
# ignored on the Stellar path (Soroban RPC has no historical state — see issue #568).
#
# Relayer Phase 0 + Phase 3 (whitelist sync) are wired below; Phase 4 (yield-mint)
# is skipped for Stellar.

# ── Stellar chain example (Relayer: whitelist sync via access_manager) ──────────
#
# These wire Phase 0 (lp_profiles seeding) and Phase 3 (on-chain whitelist sync via
# access_manager.execute(set_authorized) on the PLUSD SAC). Sumsub is gated by the
# global JOB_RELAYER_SUMSUB_ENABLED. Crystal is force-disabled on Stellar (no
# Stellar coverage in Crystal today).
#
# CHAIN_99000001_RELAYER_STELLAR_ACCESS_MANAGER_ID=CBJUO44GFUU3NTDTTNJTLLIIC6RGNAS6NLPNIJYYZKFY5NSZ3IMMZ4Q5
#   # Access-manager contract (target of `execute(...)`). Same value as the
#   # indexer's CHAIN_<id>_STELLAR_ACCESS_MANAGER_ID line above.
# CHAIN_99000001_RELAYER_STELLAR_PLUSD_SAC_ID=CAC7JMGRFZBL4IS4WBO5R3AMTK3C53FEOQZSU2WL5C4TWCRFAYWFSIBN
#   # PLUSD Stellar Asset Contract — the inner `target` of the timelock operation.
# CHAIN_99000001_RELAYER_STELLAR_SIGNER_SECRET=S...
#   # Strkey S… seed for the relayer's ed25519 key. The corresponding G… address
#   # MUST already hold the `executor` role on the access-manager. Grant it once
#   # via `just grant-executor <G-address>` in pipeline-stellar-contracts/deployments.
#   # FOLLOW-UP: replace with KMS/BitGo provisioning before mainnet (TD-17).
# Optional — RPC URL and passphrase fall back to the indexer's CHAIN_<id>_STELLAR_*
# vars when unset (single Soroban endpoint per chain in practice).
# CHAIN_99000001_RELAYER_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
# CHAIN_99000001_RELAYER_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# JOB_RELAYER_STELLAR_BATCH_SIZE=50      # optional, default 50 — max addresses processed per cycle

# ── Stellar chain example (API: Voucher signing) ──────────────
#
# These vars are PARALLEL to (not aliases of) the indexer's CHAIN_<id>_STELLAR_*
# vars above. The API and the indexer can target different deployments and evolve
# independently — a deliberate design decision (see exec plan #555 §Resolved §1).
#
# STELLAR_VERIFIER_SECRET=S...   # flat, chain-agnostic ed25519 seed (Strkey S…)
#                                # The verifier pubkey on testnet is:
#                                #   GC5SUAXMROK67LIE3DDMJG3AHHEVSFDAZ55A4WS655XYSKIN46RG7ACM
#   FOLLOW-UP: replace with KMS/BitGo provisioning before mainnet (tech-debt #555-kms).
#
# CHAIN_99000001_API_STELLAR_DM_CONTRACT_ID=CARFA2QETOZVKHSG4BCEEXMJHTYR2Z75VR7WQNX4MWZ33RQMKRKATIVI
#   # DepositManager — parallel to CHAIN_99000001_STELLAR_DEPOSIT_MANAGER_ID (indexer)
# CHAIN_99000001_API_STELLAR_WQ_CONTRACT_ID=CC3TWGFXP2XUZJXGLVTM2G4K2PF2YTC6BKDRPZIUPSVETNYAO57GU3Q7
#   # WithdrawalQueue — parallel to CHAIN_99000001_STELLAR_WITHDRAWAL_QUEUE_ID (indexer)
# CHAIN_99000001_API_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
#   # Omit for testnet sentinel (99000001) — defaults automatically.
#   # Required for non-testnet Stellar chains.
#
# Once set, the voucher endpoint dispatches on chain_kind:
#   GET /v1/deposits/<id>/voucher?wallet=G...&chain_id=99000001
# returns a 64-byte ed25519 signature hex-encoded with 0x prefix.
# Stellar voucher requests return HTTP 403 until an lp_profiles row exists
# for the wallet on this chain (same behaviour as EVM — Decision #4 of plan #555).

# ── Crystal Intelligence KYT (Worker: Relayer) ───────────────

CRYSTAL_API_KEY=                                   # required when CRYSTAL_ENABLED=true
CRYSTAL_BASE_URL=https://apiexpert.crystalblockchain.com  # optional, default https://apiexpert.crystalblockchain.com
CRYSTAL_BLOCKCHAIN=eth                             # optional, omit to check all chains; required for transaction checks
CRYSTAL_TOKEN_ID=138052                            # optional, default 0 (base asset) — see /monitor/currency/list for token IDs
CRYSTAL_RISK_SCORE_THRESHOLD=0.7                   # optional, default 0.7 (0.0–1.0)
# optional, comma-separated signal names — default: all 24 signals
CRYSTAL_HARD_FAIL_SIGNALS="child_exploitation,dark_market,dark_service,enforcement_action,exchange_fraudulent,gambling,illegal_service,mixer,ransom,sanctions,scam,stolen_coins,terrorism_financing"

# ── Frontend (VITE_) ────────────────────────────────────────────────────────

VITE_API_BASE_URL=http://localhost:8080
VITE_EVM_CHAIN_ID=560048
VITE_EVM_RPC_URL=https://ethereum-hoodi-rpc.publicnode.com
VITE_DEPOSIT_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000  # set to DepositManager contract address on Hoodi
VITE_WITHDRAWAL_QUEUE_ADDRESS=0x0000000000000000000000000000000000000000  # set to WithdrawalQueue contract address on Hoodi
VITE_STAKED_PLUSD_ADDRESS=0x0000000000000000000000000000000000000000  # set to StakedPLUSD vault address on Hoodi
VITE_WALLETCONNECT_PROJECT_ID=replace-me                                 # provision at https://cloud.reown.com

# Stellar
VITE_STELLAR_NETWORK=testnet                                             # "testnet" (default) or "mainnet"
VITE_STELLAR_CHAIN_ID=99000001                                           # backend chain_id for Stellar voucher/API dispatch
VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org             # Stellar Horizon base URL
VITE_STELLAR_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5  # Circle USDC issuer (testnet)
# VITE_STELLAR_DEPOSIT_MANAGER_ID=CARFA2QETOZVKHSG4BCEEXMJHTYR2Z75VR7WQNX4MWZ33RQMKRKATIVI  # Pipeline DepositManager Soroban contract ID (testnet 2026-06-10)
# VITE_STELLAR_WITHDRAWAL_QUEUE_ID=CC3TWGFXP2XUZJXGLVTM2G4K2PF2YTC6BKDRPZIUPSVETNYAO57GU3Q7  # Pipeline WithdrawalQueue Soroban contract ID (redeployed testnet 2026-06-16)
