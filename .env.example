# ── Shared (API + Worker) ────────────────────────────────────

POSTGRES_URL=postgres://user:password@localhost:5432/pipeline

# ── Sumsub KYC (API + Worker) ───────────────────────────────

SUMSUB_APP_TOKEN=                    # required
SUMSUB_SECRET_KEY=                   # required
SUMSUB_BASE_URL=https://api.sumsub.com  # required
SUMSUB_VERIFICATION_LEVEL=           # required, e.g. "id-and-liveness"
SUMSUB_WEBHOOK_SECRET_KEY=           # required, for webhook HMAC validation
SUMSUB_SANDBOX=false                 # optional, default false
SUMSUB_TOKEN_TTL_SECS=600           # optional, default 600

# ── API ─────────────────────────────────────────────────────

API_PORT=8080                        # optional, default 8080

# ── Worker: Jobs ──────────────────────────────────────────────

# Comma-separated list of enabled job names
ENABLED_JOB_NAMES=

# Per-job config — replace <NAME> with the uppercased job name
# JOB_<NAME>_TYPE is required: 'transfer', 'withdrawal_queue', or 'kyc_outbox'

# --- Indexer: Transfer (TYPE=transfer) ---
JOB_<NAME>_TYPE=transfer
JOB_<NAME>_ETH_RPC_URL=https://mainnet.infura.io/v3/<key>
JOB_<NAME>_CHAIN_ID=1
JOB_<NAME>_TRANSFER_CONTRACTS=0xabc...,0xdef...    # required, comma-separated ERC-20 contract addresses
JOB_<NAME>_TRANSFER_TARGETS=0xabc...,0xdef...      # required, only index transfers where from or to is in this list
JOB_<NAME>_POLLING_BLOCK_RANGE=1000                # optional, default 1000
JOB_<NAME>_POLLING_INTERVAL_MS=500                 # optional, default 500
JOB_<NAME>_LOG_CONFIRMATIONS_DELAY=12              # optional, default 12

# --- Indexer: Withdrawal Queue (TYPE=withdrawal_queue) ---
JOB_<NAME>_TYPE=withdrawal_queue
JOB_<NAME>_ETH_RPC_URL=https://mainnet.infura.io/v3/<key>
JOB_<NAME>_CHAIN_ID=1
JOB_<NAME>_WQ_CONTRACTS=0xabc...                   # required, comma-separated WithdrawalQueue contract addresses
JOB_<NAME>_POLLING_BLOCK_RANGE=1000                # optional, default 1000
JOB_<NAME>_POLLING_INTERVAL_MS=500                 # optional, default 500
JOB_<NAME>_LOG_CONFIRMATIONS_DELAY=12              # optional, default 12

# --- KYC Outbox (TYPE=kyc_outbox) ---
JOB_<NAME>_TYPE=kyc_outbox
JOB_<NAME>_INTERVAL_SECS=30                        # optional, default 30
JOB_<NAME>_BATCH_SIZE=100                          # optional, default 100
